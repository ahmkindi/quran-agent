# ---------------------------------------------------------------------------
# Copy to .env and fill in. .env is git-ignored.
# ---------------------------------------------------------------------------

# --- Google / Gemini (agent-service) ---
# DEV: get a key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Live speech-to-speech model.
GEMINI_MODEL=gemini-3.1-flash-live-preview
# Prebuilt voice name (e.g. Puck, Charon, Kore, Aoede). Empty = model default.
GEMINI_VOICE=Puck
# Endpointing: silence (ms) before the agent considers your turn finished.
# Lower = snappier but more false cut-offs; recitation has natural pauses, so
# don't go below ~400. Server default (unset/0) is ~800 ms. 400-600 is typical.
VAD_SILENCE_MS=500
# End-of-speech sensitivity: high (snappier turn end, default) | low | empty (model default).
VAD_END_SENSITIVITY=high

# PROD (Vertex AI) instead of an API key — leave GOOGLE_API_KEY empty and set:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/sa.json

# --- agent-service ---
AGENT_GRPC_ADDR=0.0.0.0:9090

# --- Quran companion ---
# Recitation reciter (islamic.network audio edition ids). Tempo varies a lot:
# ar.mahermuaiqly (fast, default), ar.alafasy, ar.shaatree, ar.husary (slow), ar.minshawi (slow).
RECITER_EDITION=ar.mahermuaiqly
# Recitation MP3 bitrate: 128 (clearer) or 64 (smaller/faster).
AUDIO_BITRATE=128
# Decoded-PCM cache budget in MiB (shared across all users; hard RAM cap). 32 suits a 2 GB box.
AUDIO_CACHE_MB=32
# Default translation edition (alquran.cloud): en.sahih, en.asad, en.pickthall, ...
TRANSLATION_EDITION=en.sahih
# Default tafsir edition (spa5k tafsir_api): en-tafisr-ibn-kathir,
# en-tafsir-maarif-ul-quran, en-al-jalalayn, ar-tafsir-muyassar, ...
TAFSIR_EDITION=en-tafisr-ibn-kathir
# Optional: override the whole system prompt (empty = built-in Quran prompt).
# AGENT_INSTRUCTION=

# --- Control-word spotter (web-service; drives a recitation without the LLM:
# stop / again / next / previous) ---
# Real engine only in images built with `-tags sherpa` (see services/web/Dockerfile);
# otherwise a no-op (no control words). The words are baked into the model's
# keywords.txt at image build via the KWS_WORDS build-arg (default
# "stop,again,next,previous"); bridge maps the detected word to a RecitationControl.
# KWS_MODEL_DIR is set in the web image; override only for a custom model.
# KWS_MODEL_DIR=/models/kws
# KWS_KEYWORDS_FILE=            # override the keywords file (default <model>/keywords.txt)
# KWS_THRESHOLD=0.25           # detection threshold (higher = stricter)
# KWS_THREADS=1

# --- web-service ---
WEB_HTTP_ADDR=0.0.0.0:8080
# Host port published for the browser UI (container always listens on 8080).
WEB_PORT=8080
# Host port published for the agent gRPC (dev only, for host tests/grpcurl).
AGENT_PORT=9090
# Where web-service reaches agent-service (docker network name in compose).
AGENT_GRPC_TARGET=agent:9090
# Comma-separated allowed Origins for the signaling WebSocket upgrade.
ALLOWED_ORIGINS=http://localhost:8080
# Cookie Secure flag — false on localhost (http), true behind HTTPS.
COOKIE_SECURE=false
# Echo suppression: while the agent speaks (+ hangover ms), stop forwarding mic
# audio so the agent's own voice (leaking via speakers) can't interrupt it.
# Default false (full duplex): browser AEC handles echo and barge-in needs the
# mic open. Set true only if a device with broken AEC makes the agent
# interrupt itself.
HALF_DUPLEX=false
MIC_HANGOVER_MS=300
# ICE: public STUN server(s), comma-separated. Empty = host candidates only
# (fine for localhost). Needed when browser and server are on different networks.
STUN_SERVERS=stun:stun.l.google.com:19302
# TURN relay (coturn; ~10-15% of real users on strict NATs need it). Browsers
# fetch these + ephemeral HMAC credentials from GET /rtc-config. Start coturn
# locally with: docker compose --profile turn up -d coturn  (always on in prod).
# Comma-separated URLs, e.g. turn:localhost:3478 (dev) or
# turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
TURN_URLS=
# Shared secret; must match coturn's --static-auth-secret.
TURN_SECRET=quran-dev-turn-secret
# Force all media through TURN (iceTransportPolicy=relay) — validates the relay
# path end-to-end; also the guaranteed fallback on hostile networks.
FORCE_RELAY=false
# Pin pion ICE media sockets to a fixed UDP range, e.g. 50700-50900 (empty =
# ephemeral). REQUIRED on servers with default-deny inbound (open the range in
# the firewall): symmetric-NAT clients' checks arrive on ports conntrack has
# never seen and get dropped, so calls stall in "connecting".
# PION_UDP_PORT_RANGE=50700-50900
# Force relay for the /livekit page only. Needed for same-LAN dev: LiveKit can't
# resolve browsers' mDNS (.local) candidates, so direct pairing fails there;
# relaying through local coturn costs <1 ms on the same box. Pion stays direct
# (pion resolves mDNS). Irrelevant on a public server (srflx works there).
LIVEKIT_FORCE_RELAY=true

# --- LiveKit (optional A/B transport; leave keys blank to disable /livekit) ---
# Browser -> LiveKit (what the frontend connects to).
LIVEKIT_WS_URL=ws://localhost:7880
# Bot -> LiveKit (server side). localhost for local `go run`; in full docker
# compose use ws://host.docker.internal:7880 (livekit runs host-networked).
LIVEKIT_HOST=ws://localhost:7880
# `livekit-server --dev` defaults to key devkey / secret secret.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# LiveKit media candidate IP. MUST be a routable host IP the browser can reach
# (NOT 127.0.0.1). Set to your host LAN IP, e.g. 192.168.20.175. `make livekit`
# auto-detects it; only needed for the compose `livekit` service.
LIVEKIT_NODE_IP=

# --- PROD only (VM + domain; see deploy/PROD.md) ---
# APP_DOMAIN=app.example.com      # web UI + pion signaling (Caddy TLS)
# LK_DOMAIN=lk.example.com        # LiveKit signaling WSS (Caddy TLS)
# TURN_DOMAIN=turn.example.com    # coturn (raw UDP/TCP, not proxied)
# ACME_EMAIL=you@example.com      # Let's Encrypt notifications
# COMPOSE_PROFILES=turn           # coturn always on in prod
# In prod also set: LIVEKIT_NODE_IP=<VM public IP>, real LIVEKIT_API_KEY /
# LIVEKIT_API_SECRET / TURN_SECRET (generation commands in deploy/PROD.md).

# --- Postgres ---
POSTGRES_USER=quran
POSTGRES_PASSWORD=quran
POSTGRES_DB=quran
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://quran:quran@postgres:5432/quran?sslmode=disable

# --- logging ---
# debug|info|warn|error ; dev uses text, prod uses json
LOG_LEVEL=debug
LOG_FORMAT=text

# --- tracing (optional) ---
# Empty = tracing off (browser HUD + per-turn logs still work with no infra).
# Set to a Jaeger/OTLP gRPC endpoint to export spans, then `make obs` for Jaeger.
#   local go run: OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
#   docker compose --profile obs: OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
