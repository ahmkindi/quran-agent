# Caddy reverse proxy for prod: automatic HTTPS (Let's Encrypt) + WSS.
# Single-domain setup — set in the server's .env (compose passes them through):
#   APP_DOMAIN   e.g. quran.kindi.dev
#   ACME_EMAIL   cert notifications
# LiveKit signaling shares the domain: the JS SDK talks to {url}/rtc, so /rtc*
# routes to livekit :7880 and everything else to web :8080 (UI + /ws + APIs).
# TURN (coturn) is NOT proxied — raw UDP/TCP straight to the VM IP.
# web + livekit are host-networked, so Caddy (also host net) proxies localhost.

{
	email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
	encode gzip

	@livekit path /rtc /rtc/*
	handle @livekit {
		reverse_proxy localhost:7880
	}

	# Jaeger tracing UI (debug), gated by basic auth. JAEGER_USER / the bcrypt
	# JAEGER_PASS_HASH come from the VM .env via the caddy service environment.
	# Jaeger serves under this base path (QUERY_BASE_PATH=/jaeger).
	@jaeger path /jaeger /jaeger/*
	handle @jaeger {
		basic_auth {
			{$JAEGER_USER} {$JAEGER_PASS_HASH}
		}
		reverse_proxy localhost:16686
	}

	handle {
		reverse_proxy localhost:8080
	}
}
